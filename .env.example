# GuestFill configuration
# Copy to .env to customize (Vite loads VITE_* and TAURI_* prefixed vars).
# For Tauri desktop builds, these are resolved at build time.
# For production, set via CI/CD or server environment.

# ─── Logging ────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARN, ERROR
VITE_GUESTFILL_LOG_LEVEL=INFO

# ─── OCR ────────────────────────────────────────────────────
# Enable online OCR providers (Azure Document Intelligence, etc.)
VITE_GUESTFILL_ENABLE_ONLINE_OCR=false

# Azure Document Intelligence credentials (only needed if ENABLE_ONLINE_OCR=true)
# These are read via Tauri IPC in desktop builds; set as env vars for CI/testing.
# VITE_GUESTFILL_AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# VITE_GUESTFILL_AZURE_API_KEY=your-api-key-here

# ─── Local Bridge ───────────────────────────────────────────
# Port for the local IPC bridge (used for auto-fill / clipboard)
VITE_GUESTFILL_LOCAL_BRIDGE_PORT=43175

# ─── Legacy (non-VITE-prefixed, kept for Tauri Rust side) ──
# GUESTFILL_LOG_LEVEL=info
# GUESTFILL_ENABLE_ONLINE_OCR=false
# GUESTFILL_LOCAL_BRIDGE_PORT=43175
