<Window x:Class="GuestFormApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Guest Registration Form"
        Width="480"
        Height="620"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, sans-serif">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16">

            <TextBlock Text="Hotel Guest Registration"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#222"
                       Margin="0,0,0,16"/>

            <TextBlock Text="Full Name" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="tbFullName"
                     AutomationProperties.AutomationId="fullName"
                     Style="{StaticResource FormTextBox}"/>

            <TextBlock Text="Gender" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="tbGender"
                     AutomationProperties.AutomationId="gender"
                     Style="{StaticResource FormTextBox}"/>

            <TextBlock Text="Date of Birth" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="tbDateOfBirth"
                     AutomationProperties.AutomationId="dateOfBirth"
                     Style="{StaticResource FormTextBox}"/>

            <TextBlock Text="Nationality" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="tbNationality"
                     AutomationProperties.AutomationId="nationality"
                     Style="{StaticResource FormTextBox}"/>

            <TextBlock Text="Passport Number" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="tbPassportNumber"
                     AutomationProperties.AutomationId="passportNumber"
                     Style="{StaticResource FormTextBox}"/>

            <TextBlock Text="Document Number" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="tbDocumentNumber"
                     AutomationProperties.AutomationId="documentNumber"
                     Style="{StaticResource FormTextBox}"/>

            <TextBlock Text="Expiry Date" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="tbExpiryDate"
                     AutomationProperties.AutomationId="expiryDate"
                     Style="{StaticResource FormTextBox}"/>

            <TextBlock Text="Issuing Country" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="tbIssuingCountry"
                     AutomationProperties.AutomationId="issuingCountry"
                     Style="{StaticResource FormTextBox}"/>

        </StackPanel>
    </ScrollViewer>
</Window>
